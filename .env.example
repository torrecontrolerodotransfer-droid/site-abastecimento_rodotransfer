# Database
DATABASE_URL=mysql://user:password@localhost:3306/abastecimento

# Node Environment
NODE_ENV=development

# JWT Secret (gere com: openssl rand -base64 32)
JWT_SECRET=seu_jwt_secret_aqui

# Manus OAuth
VITE_APP_ID=seu_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im

# Owner Info
OWNER_OPEN_ID=seu_owner_id
OWNER_NAME=Seu Nome

# Forge API (Manus)
VITE_FRONTEND_FORGE_API_KEY=sua_chave_frontend
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=sua_chave_backend
BUILT_IN_FORGE_API_URL=https://api.manus.im

# App Config
VITE_APP_TITLE=AbastecimentoApp
VITE_APP_LOGO=https://seu_logo_url

# Analytics (opcional)
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=seu_website_id
